{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "type": {
                "type": "string",
                "description": "Record type — gig_search, gig_detail, or seller_profile",
                "enum": ["gig_search", "gig_detail", "seller_profile"],
                "nullable": true,
                "example": "gig_search"
            },
            "gigId": {
                "type": "string",
                "description": "Unique identifier for this gig/record",
                "nullable": true,
                "example": "search-web_scraping-1-0"
            },
            "title": {
                "type": "string",
                "description": "Gig title or seller display name",
                "nullable": true,
                "example": "I will scrape data from any website for you"
            },
            "sellerUsername": {
                "type": "string",
                "description": "Fiverr seller username",
                "nullable": true,
                "example": "expertscraper"
            },
            "sellerLevel": {
                "type": "string",
                "description": "Fiverr seller level (Top Rated, Level 2, Level 1, New Seller)",
                "nullable": true,
                "example": "Top Rated Seller"
            },
            "price": {
                "type": "number",
                "description": "Gig starting price in USD",
                "nullable": true,
                "example": 15.00
            },
            "priceString": {
                "type": "string",
                "description": "Raw price text as displayed on Fiverr",
                "nullable": true,
                "example": "From US$15"
            },
            "rating": {
                "type": "number",
                "description": "Seller or gig rating (0.0–5.0)",
                "nullable": true,
                "example": 4.9
            },
            "reviewCount": {
                "type": "integer",
                "description": "Number of reviews/ratings",
                "nullable": true,
                "example": 247
            },
            "deliveryTime": {
                "type": "string",
                "description": "Estimated delivery time",
                "nullable": true,
                "example": "1 day delivery"
            },
            "description": {
                "type": "string",
                "description": "Gig or seller description text",
                "nullable": true,
                "example": "I will extract data from any website..."
            },
            "url": {
                "type": "string",
                "description": "Full Fiverr URL to the gig or seller profile",
                "nullable": true,
                "example": "https://www.fiverr.com/expertscraper/scrape-web-data"
            },
            "tags": {
                "type": "array",
                "description": "Tags or categories associated with the gig",
                "items": {"type": "string"},
                "nullable": true,
                "example": ["Web Scraping", "Data Entry"]
            },
            "isPro": {
                "type": "boolean",
                "description": "Whether the seller is Fiverr Pro verified",
                "nullable": true,
                "example": false
            },
            "isPromoted": {
                "type": "boolean",
                "description": "Whether this gig is a promoted/sponsored listing (search results only)",
                "nullable": true,
                "example": false
            },
            "imageUrl": {
                "type": "string",
                "description": "Gig thumbnail or gallery image URL",
                "nullable": true,
                "example": "https://fiverr-res.cloudinary.com/image/upload/t_gig_card/v1/gigs/12345.jpg"
            },
            "sellerAvatar": {
                "type": "string",
                "description": "Seller profile avatar URL",
                "nullable": true,
                "example": "https://fiverr-res.cloudinary.com/image/upload/t_profile_original/v1/avatars/12345.jpg"
            },
            "searchKeyword": {
                "type": "string",
                "description": "The search keyword that produced this result (search mode only)",
                "nullable": true,
                "example": "web scraping"
            },
            "packages": {
                "type": "array",
                "description": "Gig pricing packages/tiers (gig detail mode)",
                "items": {"type": "object"},
                "nullable": true
            },
            "faq": {
                "type": "array",
                "description": "Gig FAQ items (gig detail mode)",
                "items": {"type": "string"},
                "nullable": true
            },
            "reviews": {
                "type": "array",
                "description": "Recent reviews (gig detail mode, when include_reviews=true)",
                "items": {"type": "object"},
                "nullable": true
            },
            "badges": {
                "type": "array",
                "description": "Seller badges (seller profile mode)",
                "items": {"type": "string"},
                "nullable": true,
                "example": ["Top Rated", "Fast Response"]
            },
            "scrapedAt": {
                "type": "string",
                "description": "ISO 8601 UTC timestamp when the data was scraped",
                "nullable": true,
                "example": "2026-07-03T22:00:00+00:00"
            }
        },
        "required": [],
        "additionalProperties": true
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": [
                    "type",
                    "title",
                    "sellerUsername",
                    "price",
                    "rating",
                    "reviewCount",
                    "deliveryTime",
                    "url",
                    "scrapedAt"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "type": { "label": "Type", "format": "text" },
                    "title": { "label": "Title", "format": "text" },
                    "sellerUsername": { "label": "Seller", "format": "text" },
                    "price": { "label": "Price ($)", "format": "number" },
                    "rating": { "label": "Rating", "format": "number" },
                    "reviewCount": { "label": "Reviews", "format": "number" },
                    "deliveryTime": { "label": "Delivery", "format": "text" },
                    "url": { "label": "URL", "format": "link" },
                    "scrapedAt": { "label": "Scraped At", "format": "date" }
                }
            }
        },
        "details": {
            "title": "Full Details",
            "transformation": {
                "fields": [
                    "type",
                    "title",
                    "sellerUsername",
                    "sellerLevel",
                    "price",
                    "priceString",
                    "rating",
                    "reviewCount",
                    "deliveryTime",
                    "description",
                    "url",
                    "tags",
                    "isPro",
                    "packages",
                    "faq",
                    "badges",
                    "searchKeyword",
                    "scrapedAt"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "title": { "label": "Title", "format": "text" },
                    "sellerUsername": { "label": "Seller", "format": "text" },
                    "sellerLevel": { "label": "Level", "format": "text" },
                    "price": { "label": "Price", "format": "number" },
                    "rating": { "label": "Rating", "format": "number" },
                    "reviewCount": { "label": "Reviews", "format": "number" },
                    "deliveryTime": { "label": "Delivery", "format": "text" },
                    "description": { "label": "Description", "format": "text" },
                    "url": { "label": "URL", "format": "link" }
                }
            }
        }
    }
}